{
  "name": "ros-app",
  "version": "0.1.9",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "audit:stock": "tsx --env-file-if-exists=.env.local scripts/audit-stock.mts",
    "audit:integrity": "tsx --env-file-if-exists=.env.local scripts/audit-data-integrity.mts",
    "audit:tenant-isolation": "tsx --env-file-if-exists=.env.local scripts/audit-tenant-isolation.mts",
    "repair:tenant-relations": "tsx --env-file-if-exists=.env.local scripts/repair-tenant-relations.mts",
    "security:encrypt-credentials": "tsx --env-file-if-exists=.env.local scripts/encrypt-credentials.mts",
    "security:rotate-credential-key": "tsx --env-file-if-exists=.env.local scripts/rotate-credential-key.mts",
    "maintenance:cleanup": "tsx --env-file-if-exists=.env.local scripts/cleanup-operational-data.mts",
    "maintenance:subscriptions": "tsx --env-file-if-exists=.env.local scripts/sync-subscriptions.mts",
    "maintenance:overdue-reminders": "tsx --env-file-if-exists=.env.local scripts/send-overdue-reminders.mts",
    "preflight:production": "tsx --env-file-if-exists=.env.local scripts/production-preflight.mts",
    "verify": "prisma validate && npm run typecheck && npm run lint -- --quiet && npm run test && npm run build",
    "seed": "tsx --env-file-if-exists=.env.local prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx --env-file-if-exists=.env.local prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "iron-session": "^8.0.4",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.23.0",
    "midtrans-client": "^1.4.3",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.2",
    "resend": "^6.17.2",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "write-excel-file": "^4.1.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/midtrans-client": "^1.4.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
