// =============================================================================
// ROASTERY OPERATING SYSTEM (ROS) — NALWENG ROASTERY
// schema.prisma · PostgreSQL · Prisma ORM
// =============================================================================
// Arsitektur: 14 tabel inti, immutable transactions, ledger-driven stock.
// Stok TIDAK PERNAH diubah manual — hanya via mutasi transaksi.
// Koreksi dilakukan via VOID, bukan UPDATE.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  SUPERADMIN // web owner / system admin
  OWNER // full access
  MANAGER // semua modul, tanpa user management
  OPERATOR // input transaksi hulu & tengah
  CASHIER // input penjualan & payment
}

enum SubscriptionTier {
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum ProductType {
  GREEN_BEAN // biji kopi mentah
  ROASTED_BEAN // biji kopi yang sudah di-roast
  FINISHED_GOODS // produk jadi siap jual
  PACKAGING //Packaging
}

enum RoastLevel {
  LIGHT
  MEDIUM
  MEDIUM_DARK
  DARK
}

enum PurchaseType {
  GREEN_BEAN // pembelian biji kopi mentah
  PACKAGING // pembelian bahan kemasan
}

enum TransactionStatus {
  PENDING // belum dieksekusi / dalam proses
  COMPLETED // selesai, stok sudah dimutasi
  VOID // dibatalkan, mutasi stok sudah dibalik
}

enum InvoiceStatus {
  DRAFT // nota belum diterbitkan
  ISSUED // nota diterbitkan, belum bayar
  PARTIAL // bayar sebagian
  PAID // lunas
  VOID // dibatalkan
}

enum CustomerTier {
  RETAIL
  WHOLESALE_SILVER
  WHOLESALE_GOLD
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
  CREDIT // piutang / COD jatuh tempo
}

enum PurchasePaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum LedgerEntryType {
  IN // stok masuk
  OUT // stok keluar
}

enum JobRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

enum ExpenseCategory {
  GAJI // Gaji & tunjangan karyawan
  UTILITAS // Listrik, air, internet
  OPERASIONAL // Sewa tempat, bahan habis pakai, dll.
  LAINNYA // Pengeluaran lain-lain
}

/// Jenis transaksi asal untuk audit trail di InventoryLedger
enum LedgerRefType {
  PURCHASE_GB // Green Bean masuk via Purchase
  PURCHASE_PKG // Packaging masuk via Purchase
  ROASTING_GB_OUT // Green Bean keluar ke roasting
  ROASTING_RB_IN // Roasted Bean masuk dari roasting
  PRODUCTION_RB_OUT // Roasted Bean keluar ke produksi
  PRODUCTION_PKG_OUT // Packaging keluar ke produksi
  PRODUCTION_FG_IN // Finished Goods masuk dari produksi
  SALE_FG_OUT // Finished Goods keluar via penjualan
  ADJUSTMENT_IN // Penyesuaian stok masuk (Opname)
  ADJUSTMENT_OUT // Penyesuaian stok keluar (Opname)
  VOID_REVERSAL // entri kebalikan saat VOID
}

// =============================================================================
// TABLE 0 · Tenant (SaaS Multi-Tenancy)
// =============================================================================

model Tenant {
  id                   String  @id @default(cuid())
  code                 String  @unique
  name                 String
  subdomain            String? @unique
  themeColor           String  @default("amber")
  logoUrl              String?
  heroImageUrl         String?
  heroText             String?
  backgroundImageUrl   String?
  whatsappNumber       String?
  contactEmail         String?
  instagramHandle      String?
  aboutText            String?
  catalogTitle         String?
  catalogSubtitle      String?
  footerText           String?
  problemStatement     String?
  solutionStatement    String?
  uspText              String?
  features             Json?
  testimonials         Json?
  faqs                 Json?
  midtransClientKey    String?
  midtransServerKey    String?
  midtransIsProduction Boolean @default(false)
  isArtisanEnabled     Boolean @default(false)
  artisanWebhookToken  String? @unique
  layoutStyle          String  @default("modern")
  fontFamily           String  @default("sans")
  themeMode            String  @default("light")
  borderRadius         String  @default("md")
  animationStyle       String  @default("subtle")
  animationDirection   String  @default("up")
  iconStyle            String  @default("regular")
  isActive             Boolean @default(true)
  themeConfig          Json?
  timezone             String  @default("Asia/Jakarta")

  // Subscription & Billing Fields
  subscriptionTier   SubscriptionTier   @default(TRIAL)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  trialEndsAt        DateTime?
  nextBillingDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  customers             Customer[]
  suppliers             Supplier[]
  products              Product[]
  packagings            Packaging[]
  recipes               Recipe[]
  purchases             Purchase[]
  purchaseOrders        PurchaseOrder[]
  purchaseOrderItems    PurchaseOrderItem[]
  parentRoastingBatches ParentRoastingBatch[]
  productionBatches     ProductionBatch[]
  invoices              Invoice[]
  payments              Payment[]
  supplierPayments      SupplierPayment[]
  inventoryLedgers      InventoryLedger[]
  expenses              Expense[]
  subscriptionPayments  SubscriptionPayment[]
  auditLogs             AuditLog[]
  webhookEvents         WebhookEvent[]
  reminderDeliveries    ReminderDelivery[]
  recipeItems           RecipeItem[]
  childRoastingBatches  ChildRoastingBatch[]
  invoiceItems          InvoiceItem[]
  jobRuns               JobRun[]
  dailyBriefSnapshots   DailyBriefSnapshot[]

  @@map("tenants")
}

// =============================================================================
// TABLE 0.5 · SubscriptionPayment (SaaS Billing)
// =============================================================================

model SubscriptionPayment {
  id              String           @id @default(cuid())
  tenantId        String
  amount          Decimal          @db.Decimal(12, 2)
  status          String // "PENDING", "SUCCESS", "FAILED"
  midtransOrderId String           @unique
  paymentUrl      String?
  tier            SubscriptionTier

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("subscription_payments")
}

// =============================================================================
// TABLE 1 · User
// =============================================================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // bcrypt hash
  role      UserRole @default(OPERATOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases             Purchase[]
  purchaseOrders        PurchaseOrder[]
  parentRoastingBatches ParentRoastingBatch[]
  productionBatches     ProductionBatch[]
  invoices              Invoice[]
  payments              Payment[]
  supplierPayments      SupplierPayment[]
  ledgerEntries         InventoryLedger[]
  expenses              Expense[]
  auditLogs             AuditLog[]
  passwordResetTokens   PasswordResetToken[]
  tenantId              String                @default("default")
  tenant                Tenant                @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// =============================================================================
// TABLE 2 · Customer
// =============================================================================

model Customer {
  id        String       @id @default(cuid())
  code      String // e.g., "CST-001"
  name      String
  phone     String?
  email     String?
  address   String?
  tier      CustomerTier @default(RETAIL)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  invoices Invoice[]
  tenantId String    @default("default")
  tenant   Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("customers")
}

// =============================================================================
// TABLE 3 · Supplier
// =============================================================================

model Supplier {
  id        String   @id @default(cuid())
  code      String // e.g., "SUP-001"
  name      String
  phone     String?
  address   String?
  region    String? // wilayah asal (Gayo, Toraja, Flores, dsb.)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases      Purchase[]
  purchaseOrders PurchaseOrder[]
  tenantId       String          @default("default")
  tenant         Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("suppliers")
}

// =============================================================================
// TABLE 4 · Product
// Mewakili semua jenis kopi: Green Bean, Roasted Bean, dan Finished Goods.
// Stok dihitung dari agregasi InventoryLedger, BUKAN disimpan di sini.
// =============================================================================

model Product {
  id                String      @id @default(cuid())
  code              String // e.g., "GB-GAYO-001", "RB-ETHIOPIA-MED", "FG-BLEND-250"
  name              String
  type              ProductType
  category          String? // e.g. "Espresso Base", "Specialty"
  origin            String? // asal kopi: "Gayo", "Ethiopia Yirgacheffe", dsb.
  roastLevel        RoastLevel? // hanya relevan untuk ROASTED_BEAN
  sourceGreenBeanId String? // exact GREEN_BEAN identity used to create this ROASTED_BEAN
  description       String?
  imageUrl          String? // URL gambar produk
  price             Decimal?    @default(0) @db.Decimal(12, 2) // Harga jual retail
  priceSilver       Decimal?    @default(0) @db.Decimal(12, 2) // Harga jual Wholesale Silver
  priceGold         Decimal?    @default(0) @db.Decimal(12, 2) // Harga jual Wholesale Gold
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Caching Field untuk Performa
  stockUnit    Int      @default(0) // Cache jumlah unit (FG)
  stockKg      Decimal  @default(0) @db.Decimal(10, 3) // Cache berat kg (GB/RB)
  lastHpp      Decimal? @db.Decimal(12, 2) // HPP terakhir untuk FG
  avgCostPerKg Decimal? @default(0) @db.Decimal(12, 2) // Moving average HPP

  // Reorder alert configuration
  reorderAlertEnabled Boolean @default(false)
  leadTimeDays        Int     @default(7)
  safetyStockQuantity Decimal @default(0) @db.Decimal(10, 3)
  reorderLookbackDays Int     @default(30)

  // Relasi transaksi hulu
  purchases          Purchase[]
  purchaseOrderItems PurchaseOrderItem[]
  roastingInputs     ParentRoastingBatch[] @relation("RoastingInput")
  roastingOutputs    ParentRoastingBatch[] @relation("RoastingOutput")
  sourceGreenBean    Product?              @relation("GreenBeanRoastOutputs", fields: [sourceGreenBeanId], references: [id], onDelete: SetNull)
  roastLevelOutputs  Product[]             @relation("GreenBeanRoastOutputs")

  // Relasi resep & produksi
  recipeItems       RecipeItem[]
  recipes           Recipe[]
  productionBatches ProductionBatch[]

  // Relasi hilir
  invoiceItems InvoiceItem[]

  // Ledger
  ledgerEntries InventoryLedger[]
  tenantId      String            @default("default")
  tenant        Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@unique([tenantId, sourceGreenBeanId, roastLevel])
  @@index([tenantId, type, isActive])
  @@index([tenantId, sourceGreenBeanId])
  @@map("products")
}

// =============================================================================
// TABLE 5 · Packaging
// Kemasan fisik: zipper bag, kraft box, dll.
// Stok dihitung dari InventoryLedger, BUKAN disimpan di kolom ini.
// =============================================================================

model Packaging {
  id             String   @id @default(cuid())
  code           String // e.g., "PKG-ZIPPER-250"
  name           String // "Zipper Bag 250g", "Kraft Box 1kg"
  weightGrams    Decimal  @db.Decimal(8, 2) // berat kemasan kosong (gram)
  costPerUnit    Decimal  @db.Decimal(12, 2) // HPP kemasan per unit
  avgCostPerUnit Decimal? @default(0) @db.Decimal(12, 2) // Moving average HPP kemasan per unit
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Caching Field untuk Performa
  stockUnit Int @default(0) // Cache jumlah unit tersedia

  // Reorder alert configuration
  reorderAlertEnabled Boolean @default(false)
  leadTimeDays        Int     @default(7)
  safetyStockQuantity Int     @default(0)
  reorderLookbackDays Int     @default(30)

  purchases          Purchase[]
  purchaseOrderItems PurchaseOrderItem[]
  recipes            Recipe[]
  productionBatches  ProductionBatch[]
  ledgerEntries      InventoryLedger[]
  tenantId           String              @default("default")
  tenant             Tenant              @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("packagings")
}

// =============================================================================
// TABLE 6 · Recipe
// Template formula satu SKU Finished Goods: komposisi RB + kemasan + gramasi.
// =============================================================================

model Recipe {
  id          String   @id @default(cuid())
  code        String // e.g., "RCP-HOUSE-BLEND-250"
  name        String // "House Blend 250g"
  productId   String // FK → Product (type = FINISHED_GOODS)
  packagingId String // FK → Packaging default untuk resep ini
  outputGrams Decimal  @db.Decimal(8, 2) // gram kopi bersih per unit output
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product           Product           @relation(fields: [productId], references: [id])
  packaging         Packaging         @relation(fields: [packagingId], references: [id])
  items             RecipeItem[]
  productionBatches ProductionBatch[]
  tenantId          String            @default("default")
  tenant            Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("recipes")
}

// =============================================================================
// TABLE 7 · RecipeItem
// Komponen Roasted Bean dalam sebuah resep (bisa blending multi-origin).
// ratioPercent: persentase dalam blend (semua item dalam 1 recipe harus = 100%).
// gramsPerUnit: gram RB untuk 1 unit output (= outputGrams * ratioPercent / 100).
// =============================================================================

model RecipeItem {
  id           String  @id @default(cuid())
  recipeId     String
  productId    String // FK → Product (type = ROASTED_BEAN)
  ratioPercent Decimal @db.Decimal(5, 2) // % kontribusi dalam blend
  gramsPerUnit Decimal @db.Decimal(8, 3) // gram RB per 1 unit output

  recipe   Recipe  @relation(fields: [recipeId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  tenantId String  @default("default")
  tenant   Tenant  @relation(fields: [tenantId], references: [id])

  // Satu jenis RB hanya boleh muncul sekali per resep
  @@unique([recipeId, productId])
  @@index([tenantId])
  @@map("recipe_items")
}

// =============================================================================
// TABLE 8 · Purchase (Barang Datang)
// Mencatat penerimaan Green Bean ATAU Packaging dari supplier.
// type = GREEN_BEAN → productId wajib, packagingId null.
// type = PACKAGING  → packagingId wajib, productId null.
// Saat status → COMPLETED: InventoryLedger IN di-insert otomatis oleh server.
// Saat VOID: InventoryLedger OUT (reversal) di-insert otomatis.
// =============================================================================

model Purchase {
  id           String       @id @default(cuid())
  code         String // e.g., "PUR-2024-001"
  operationKey String? // Idempotency key supplied by the receiving command
  type         PurchaseType

  supplierId  String
  productId   String? // wajib jika type = GREEN_BEAN
  packagingId String? // wajib jika type = PACKAGING

  weightKg      Decimal? @db.Decimal(10, 3) // GREEN_BEAN: berat masuk (kg)
  quantityUnits Int? // PACKAGING: jumlah unit masuk

  pricePerUnit Decimal @db.Decimal(12, 2) // per kg (GB) atau per unit (PKG)
  shippingCost Decimal @default(0) @db.Decimal(12, 2) // ongkos kirim total
  totalCost    Decimal @db.Decimal(14, 2) // = qty * pricePerUnit + shippingCost (dihitung server)

  status        TransactionStatus     @default(PENDING)
  paymentStatus PurchasePaymentStatus @default(PAID)
  paidAmount    Decimal               @default(0) @db.Decimal(14, 2)
  dueDate       DateTime?
  receivedAt    DateTime              @default(now())
  notes         String?
  voidReason    String?
  voidAt        DateTime?

  createdById String
  createdAt   DateTime @default(now())

  // PO Lite reference (nullable untuk backward compat)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  supplier  Supplier          @relation(fields: [supplierId], references: [id])
  product   Product?          @relation(fields: [productId], references: [id])
  packaging Packaging?        @relation(fields: [packagingId], references: [id])
  createdBy User              @relation(fields: [createdById], references: [id])
  payments  SupplierPayment[]
  tenantId  String            @default("default")
  tenant    Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@unique([tenantId, operationKey])
  @@index([tenantId, receivedAt])
  @@index([tenantId, status])
  @@index([tenantId, paymentStatus, dueDate])
  @@index([tenantId, purchaseOrderId])
  @@map("purchases")
}

// =============================================================================
// TABLE 9 · ParentRoastingBatch & ChildRoastingBatch
// Fase Pagi: ParentBatch dibuat dengan target input (Green Bean).
// Fase Siang: ChildBatch masuk otomatis via webhook Artisan (Zero-Touch).
// Fase Sore: ParentBatch diselesaikan (COMPLETED) dengan menginput hasil akhir (Roasted Bean),
// memicu pemotongan stok & penambahan stok secara borongan.
// =============================================================================

model ParentRoastingBatch {
  id           String  @id @default(cuid())
  code         String // e.g., "PRST-2024-001"
  operationKey String? // Idempotency key supplied by the roast command
  tenantId     String  @default("default")

  inputProductId String // FK → Product (type = GREEN_BEAN)
  targetWeightKg Decimal @db.Decimal(10, 3) // Target dari Gudang Pagi (Misal: 20 Kg)

  outputProductId String // FK → Product (type = ROASTED_BEAN)
  actualOutputKg  Decimal? @db.Decimal(10, 3) // Hasil Akhir Sore (Misal: 16.5 Kg)

  totalShrinkagePercent Decimal?          @db.Decimal(5, 2)
  status                TransactionStatus @default(PENDING) // PENDING (Aktif), COMPLETED, VOID

  notes      String?
  voidReason String?
  voidAt     DateTime?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
  createdById String // FK → User (Roaster)

  inputProduct  Product @relation("RoastingInput", fields: [inputProductId], references: [id])
  outputProduct Product @relation("RoastingOutput", fields: [outputProductId], references: [id])
  createdBy     User    @relation(fields: [createdById], references: [id])
  tenant        Tenant  @relation(fields: [tenantId], references: [id])

  childBatches ChildRoastingBatch[]

  @@unique([tenantId, code])
  @@unique([tenantId, operationKey])
  @@index([tenantId, status, createdAt])
  @@map("parent_roasting_batches")
}

model ChildRoastingBatch {
  id       String @id @default(cuid())
  parentId String

  artisanEventId String?  @unique // Mencegah duplikasi webhook (idempotency)
  roastDuration  Int? // Durasi sangrai dalam detik
  dropTemp       Decimal? @db.Decimal(5, 2) // Suhu saat drop (suhu sebelum crash)

  recordedAt DateTime @default(now()) // Waktu webhook masuk

  parent   ParentRoastingBatch @relation(fields: [parentId], references: [id], onDelete: Cascade)
  tenantId String              @default("default")
  tenant   Tenant              @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("child_roasting_batches")
}

// =============================================================================
// TABLE 10 · ProductionBatch (Blending + Packaging → Finished Goods)
// Mengeksekusi sebuah Recipe untuk N unit output.
// Server otomatis menghitung & mengkonsumsi: RB (per RecipeItem) + Packaging.
// hppPerUnit = (total HPP RB terpakai + total HPP packaging) / unitsProduced.
// Saat COMPLETED: Ledger RB OUT + PKG OUT + FG IN di-insert otomatis.
// Saat VOID: reversal otomatis.
// =============================================================================

model ProductionBatch {
  id           String  @id @default(cuid())
  code         String // e.g., "PRD-2024-001"
  operationKey String? // Idempotency key supplied by the production command

  recipeId        String? // FK → Recipe (opsional: null jika produksi bebas tanpa template resep)
  outputProductId String // FK → Product (type = FINISHED_GOODS)
  packagingId     String // bisa berbeda dari default resep (misal: kehabisan stok)

  unitsProduced Int // jumlah unit yang diproduksi
  totalRbUsedKg Decimal @db.Decimal(10, 3) // total RB terpakai (kg), dihitung server
  hppPerUnit    Decimal @db.Decimal(12, 2) // HPP per unit, snapshot saat produksi

  status     TransactionStatus @default(COMPLETED)
  producedAt DateTime          @default(now())
  notes      String?
  voidReason String?
  voidAt     DateTime?

  createdById String
  createdAt   DateTime @default(now())

  recipe        Recipe?   @relation(fields: [recipeId], references: [id])
  outputProduct Product   @relation(fields: [outputProductId], references: [id])
  packaging     Packaging @relation(fields: [packagingId], references: [id])
  createdBy     User      @relation(fields: [createdById], references: [id])
  tenantId      String    @default("default")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@unique([tenantId, operationKey])
  @@index([tenantId, status, producedAt])
  @@map("production_batches")
}

// =============================================================================
// TABLE 11 · Invoice (Nota Penjualan)
// Header nota. Status naik otomatis saat Payment masuk.
// VOID membalik semua mutasi stok dari InvoiceItem.
// =============================================================================

model Invoice {
  id           String  @id @default(cuid())
  code         String // e.g., "INV-2024-001"
  operationKey String? // Idempotency key supplied by the client command

  customerId String

  subtotal        Decimal @db.Decimal(14, 2) // sebelum diskon, pajak & ongkir
  discount        Decimal @default(0) @db.Decimal(14, 2)
  tax             Decimal @default(0) @db.Decimal(14, 2)
  shippingCost    Decimal @default(0) @db.Decimal(14, 2) // ongkos kirim
  shippingMethod  String? // "PICKUP", "LOCAL_DELIVERY", "COURIER"
  shippingAddress String? // alamat spesifik jika dikirim
  courierName     String? // nama ekspedisi
  trackingNumber  String? // nomor resi
  grandTotal      Decimal @db.Decimal(14, 2) // = subtotal - discount + tax + shippingCost

  paidAmount Decimal       @default(0) @db.Decimal(14, 2) // diupdate server tiap Payment masuk
  status     InvoiceStatus @default(DRAFT)

  issuedAt DateTime  @default(now())
  dueDate  DateTime?

  notes      String?
  voidReason String?
  voidAt     DateTime?

  createdById String
  createdAt   DateTime @default(now())

  customer           Customer           @relation(fields: [customerId], references: [id])
  createdBy          User               @relation(fields: [createdById], references: [id])
  items              InvoiceItem[]
  payments           Payment[]
  reminderDeliveries ReminderDelivery[]
  tenantId           String             @default("default")
  tenant             Tenant             @relation(fields: [tenantId], references: [id])

  midtransOrderId String? @unique
  paymentUrl      String?
  paymentMethod   String?

  @@unique([tenantId, code])
  @@unique([tenantId, operationKey])
  @@index([tenantId, status, issuedAt])
  @@index([tenantId, customerId, issuedAt])
  @@map("invoices")
}

// =============================================================================
// TABLE 12 · InvoiceItem
// Line item per SKU dalam nota. Immutable setelah Invoice di-ISSUED.
// hpp: snapshot HPP dari ProductionBatch terakhir saat Invoice dibuat.
// margin = (unitPrice - discount) - hpp  →  dihitung di query/laporan.
// =============================================================================

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String
  productId String // FK → Product (type = FINISHED_GOODS)

  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  discount  Decimal @default(0) @db.Decimal(12, 2) // diskon per unit
  subtotal  Decimal @db.Decimal(14, 2) // = (unitPrice - discount) * quantity, dihitung server
  hpp       Decimal @db.Decimal(12, 2) // snapshot HPP per unit saat transaksi

  invoice  Invoice @relation(fields: [invoiceId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  tenantId String  @default("default")
  tenant   Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("invoice_items")
}

// =============================================================================
// TABLE 13 · Payment
// Pembayaran atas sebuah Invoice. Immutable. Koreksi via VOID.
// Server update Invoice.paidAmount & Invoice.status setelah tiap Payment.
// =============================================================================

model Payment {
  id   String @id @default(cuid())
  code String // e.g., "PAY-2024-001"

  invoiceId String

  amount    Decimal       @db.Decimal(14, 2)
  method    PaymentMethod @default(CASH)
  reference String? // no. referensi transfer / QRIS
  paidAt    DateTime      @default(now())

  notes      String?
  voidReason String?
  voidAt     DateTime?

  createdById String
  createdAt   DateTime @default(now())

  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])
  tenantId  String  @default("default")
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, paidAt])
  @@index([tenantId, invoiceId])
  @@map("payments")
}

// =============================================================================
// TABLE 13B · SupplierPayment
// Pembayaran hutang atas Purchase. Koreksi dilakukan melalui VOID.
// Purchase.paidAmount dan Purchase.paymentStatus diperbarui secara atomik.
// =============================================================================

model SupplierPayment {
  id   String @id @default(cuid())
  code String // e.g., "SPAY-2024-001"

  purchaseId String

  amount    Decimal       @db.Decimal(14, 2)
  method    PaymentMethod @default(CASH)
  reference String?
  paidAt    DateTime      @default(now())

  notes      String?
  voidReason String?
  voidAt     DateTime?

  createdById String
  createdAt   DateTime @default(now())

  purchase  Purchase @relation(fields: [purchaseId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])
  tenantId  String   @default("default")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, paidAt])
  @@index([tenantId, purchaseId])
  @@map("supplier_payments")
}

// =============================================================================
// TABLE 14 · InventoryLedger  ★ PUSAT MUTASI STOK ★
// Satu baris = satu event perubahan stok. Append-only. TIDAK PERNAH diedit.
// Koreksi via VOID_REVERSAL (entri baru dengan nilai negatif/berlawanan).
//
// Aturan pengisian:
//   • Entri kopi (GB/RB/FG) → productId diisi, packagingId null
//   • Entri kemasan (PKG)   → packagingId diisi, productId null
//   • quantityKg  → untuk GB dan RB (satuan kilogram)
//   • quantityUnit → untuk FG dan Packaging (satuan unit/pcs)
// =============================================================================

model InventoryLedger {
  id String @id @default(cuid())

  productId   String? // FK → Product (GB / RB / FG)
  packagingId String? // FK → Packaging

  entryType LedgerEntryType // IN | OUT
  refType   LedgerRefType // jenis transaksi asal
  refId     String // ID transaksi asal (Purchase.id, RoastingBatch.id, dsb.)

  quantityKg   Decimal? @db.Decimal(10, 3) // diisi untuk GB & RB
  quantityUnit Int? // diisi untuk FG & Packaging

  notes String?

  createdById String
  createdAt   DateTime @default(now())

  product   Product?   @relation(fields: [productId], references: [id])
  packaging Packaging? @relation(fields: [packagingId], references: [id])
  createdBy User       @relation(fields: [createdById], references: [id])

  // Index untuk kalkulasi stok realtime per produk/packaging
  tenantId String @default("default")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, productId, createdAt])
  @@index([tenantId, packagingId, createdAt])
  // Index untuk audit trail per transaksi
  @@index([tenantId, refType, refId])
  @@map("inventory_ledger")
}

// =============================================================================
// TABLE 15 · Expense (Pengeluaran / OPEX)
// Mencatat semua pengeluaran operasional untuk kalkulasi Laba Bersih di P&L.
// Immutable — koreksi via void / pencatatan ulang.
// =============================================================================

model Expense {
  id          String          @id @default(cuid())
  date        DateTime
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(14, 2)
  description String?
  voidReason  String?
  voidAt      DateTime?

  createdById String
  createdAt   DateTime @default(now())

  createdBy User   @relation(fields: [createdById], references: [id])
  tenantId  String @default("default")
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, date])
  @@index([tenantId, category])
  @@map("expenses")
}

// =============================================================================
// PLATFORM AUDIT & INTEGRATION INBOX
// =============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

model WebhookEvent {
  id          String    @id @default(cuid())
  tenantId    String
  provider    String
  eventId     String
  eventType   String
  status      String    @default("RECEIVED")
  payload     Json
  error       String?
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, provider, eventId])
  @@index([tenantId, provider, receivedAt])
  @@index([status, receivedAt])
  @@map("webhook_events")
}

model ReminderDelivery {
  id           String    @id @default(cuid())
  tenantId     String
  invoiceId    String
  channel      String
  reminderDate DateTime  @db.Date
  status       String    @default("PENDING")
  error        String?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, invoiceId, channel, reminderDate])
  @@index([tenantId, reminderDate, status])
  @@map("reminder_deliveries")
}

model JobRun {
  id         String       @id @default(cuid())
  tenantId   String?
  jobName    String
  runKey     String       @unique
  status     JobRunStatus @default(RUNNING)
  attempt    Int          @default(1)
  startedAt  DateTime     @default(now())
  finishedAt DateTime?
  summary    Json?
  error      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([jobName, startedAt])
  @@index([status, startedAt])
  @@index([tenantId, startedAt])
  @@map("job_runs")
}

model DailyBriefSnapshot {
  id          String   @id @default(cuid())
  tenantId    String
  reportDate  DateTime @db.Date
  periodStart DateTime
  periodEnd   DateTime
  generatedAt DateTime @default(now())
  payload     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, reportDate])
  @@index([tenantId, generatedAt])
  @@map("daily_brief_snapshots")
}

model RateLimitBucket {
  key         String   @id
  count       Int      @default(1)
  windowStart DateTime
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
  @@map("rate_limit_buckets")
}

// =============================================================================
// TABLE · PurchaseOrder (PO Lite)
// Purchase Order sederhana yang terintegrasi dengan Reorder Point Alert.
// =============================================================================

enum POStatus {
  DRAFT // Belum dikirim
  SENT // Sudah dikirim ke supplier
  PARTIAL // Sebagian barang diterima
  RECEIVED // Semua barang diterima
  CANCELLED // Dibatalkan
}

model PurchaseOrder {
  id     String   @id @default(cuid())
  code   String // PO-YYYYMM-NNN
  status POStatus @default(DRAFT)

  // Supplier
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  // Snapshot data saat PO dibuat
  expectedDate DateTime? // Tanggal perkiraan barang datang
  notes        String?

  // Financial
  totalEstimate Decimal? @db.Decimal(12, 2) // Total estimasi biaya

  // Tracking
  sentAt     DateTime? // Kapan PO dikirim ke supplier
  receivedAt DateTime? // Kapan barang diterima

  // Audit
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Tenant
  tenantId String @default("default")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Relations
  items     PurchaseOrderItem[]
  purchases Purchase[] // Link ke Purchase saat barang datang (bisa multi untuk partial receipt)

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  // Produk
  productId   String?
  product     Product?   @relation(fields: [productId], references: [id])
  packagingId String?
  packaging   Packaging? @relation(fields: [packagingId], references: [id])

  // Quantity & Harga
  quantity   Decimal @db.Decimal(10, 3) // kg atau unit
  unitPrice  Decimal @db.Decimal(12, 2) // Harga per kg/unit
  totalPrice Decimal @db.Decimal(12, 2) // quantity × unitPrice

  // Reorder reference (dari mana data ini)
  reorderPoint Decimal? @db.Decimal(10, 3) // Snapshot reorder point saat PO dibuat
  currentStock Decimal? @db.Decimal(10, 3) // Snapshot stok saat PO dibuat

  createdAt DateTime @default(now())

  tenantId String @default("default")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, purchaseOrderId])
  @@map("purchase_order_items")
}
