# DATABASE
DATABASE_URL="postgresql://user:PASSWORD@host:6543/database?pgbouncer=true"
DIRECT_URL="postgresql://user:PASSWORD@host:5432/database"

# SESSION (minimum 32 characters)
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"

# MIDTRANS (production keys)
# MIDTRANS_SERVER_KEY="Mid-server-xxx"
# NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="Mid-client-xxx"
# MIDTRANS_IS_PRODUCTION="true"

# ARTISAN DESKTOP INTEGRATION
# ARTISAN_CONNECTOR_TOKEN_PEPPER="random-pepper-for-connector-tokens"
# ARTISAN_PAIRING_CODE_PEPPER="random-pepper-for-pairing-codes"
# ARTISAN_MAX_UPLOAD_BYTES=10485760
# ARTISAN_CONNECTOR_DOWNLOAD_URL="https://your-domain.com/downloads/artisan-sync.exe"
