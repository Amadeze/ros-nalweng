# Salin file ini ke .env.local dan isi dengan nilai yang sesuai.
# cp .env.local.example .env.local

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#DATABASE_URL="postgresql://postgres:password@localhost:5432/ros_nalweng"
DATABASE_URL="postgresql://user:password@host:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Iron Session Secret (Must be >= 32 characters)
SESSION_SECRET="your-32-character-long-secret-key-goes-here"
CREDENTIAL_ENCRYPTION_KEY="a-different-32-character-secret-for-credentials"
# Only needed temporarily while rotating an existing dedicated key.
OLD_CREDENTIAL_ENCRYPTION_KEY=""
APP_URL="http://localhost:3000"
CRON_SECRET="replace-with-a-long-random-secret"

# Midtrans Configuration (Superadmin/SaaS)
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_IS_PRODUCTION="false"

# Email
RESEND_API_KEY=""
EMAIL_FROM="Roastery OS <no-reply@example.com>"

# Supabase Storage (required for production uploads)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="ros-assets"

# Optional WhatsApp provider
WA_API_KEY=""
WA_API_URL="https://api.fonnte.com/send"
